#include <WiFi.h>
#include <HTTPClient.h>

// ================= DEFIDISI PIN SENSOR =================
#define TRIG_PIN1 4
#define ECHO_PIN1 5

#define TRIG_PIN2 18
#define ECHO_PIN2 19

#define TRIG_PIN3 21
#define ECHO_PIN3 22

// ================= DEFINISI PIN BUZZER =================
#define BUZZER_PIN1 12  // Silakan sesuaikan dengan pin GPIO ESP32-S3 Anda
#define BUZZER_PIN2 13  // Silakan sesuaikan dengan pin GPIO ESP32-S3 Anda

// ================= TIMING & STATE (NON-BLOCKING) =================
unsigned long waktuSebelumnyaKirim = 0;
const long intervalKirim = 2000; // Timer kirim data ke DB setiap 2 detik

unsigned long waktuBuzzer1 = 0;
unsigned long waktuBuzzer2 = 0;
bool statusBuzzer1 = LOW;
bool statusBuzzer2 = LOW;

// Variabel Global untuk menyimpan jarak terakhir
float jarak1 = 999.0;
float jarak2 = 999.0;
float jarak3 = 999.0;

const char* ssid = "idil";            
const char* password = "123456789";   
const char* serverName = "http://192.168.43.212/esp32/insert.php"; 

// Fungsi membaca jarak
float ambilJarak(int trigPin, int echoPin) {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  
  long durasi = pulseIn(echoPin, HIGH, 30000); 
  float jarak = durasi * 0.034 / 2;
  
  // KOREKSI: Jika error, kembalikan 999 agar terdeteksi sebagai jarak "Jauh" (Aman)
  if (jarak <= 0 || jarak > 400) {
    return 999.0; 
  }
  return jarak;
}

void setup() {
  Serial.begin(115200);
  
  // Inisialisasi Pin Sensor
  pinMode(TRIG_PIN1, OUTPUT); pinMode(ECHO_PIN1, INPUT);
  pinMode(TRIG_PIN2, OUTPUT); pinMode(ECHO_PIN2, INPUT);
  pinMode(TRIG_PIN3, OUTPUT); pinMode(ECHO_PIN3, INPUT);

  // Inisialisasi Pin Buzzer
  pinMode(BUZZER_PIN1, OUTPUT);
  pinMode(BUZZER_PIN2, OUTPUT);

  WiFi.begin(ssid, password);
  Serial.print("Menghubungkan ke WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nTerhubung ke WiFi");
}

void loop() {
  // Ambil waktu saat ini berjalan
  unsigned long waktuSekarang = millis();

  // -----------------------------------------------------------------
  // LOGIKA 1: BACA SENSOR & KIRIM KE DATABASE (Berjalan setiap 2 detik)
  // -----------------------------------------------------------------
  if (waktuSekarang - waktuSebelumnyaKirim >= intervalKirim) {
    waktuSebelumnyaKirim = waktuSekarang;

    jarak1 = ambilJarak(TRIG_PIN1, ECHO_PIN1);
    delay(50); // Jeda tipis antar sensor agar tidak ada benturan gelombang (crosstalk)
    jarak2 = ambilJarak(TRIG_PIN2, ECHO_PIN2);
    delay(50);
    jarak3 = ambilJarak(TRIG_PIN3, ECHO_PIN3);

    // Tampilkan di Serial Monitor (Jika 999, tampilkan info Error/Out of Range)
    Serial.print("J1: "); Serial.print(jarak1 == 999.0 ? "N/A" : String(jarak1)); Serial.print(" cm | ");
    Serial.print("J2: "); Serial.print(jarak2 == 999.0 ? "N/A" : String(jarak2)); Serial.print(" cm | ");
    Serial.print("J3: "); Serial.println(jarak3 == 999.0 ? "N/A" : String(jarak3));

    if (WiFi.status() == WL_CONNECTED) {
      HTTPClient http;
      http.begin(serverName);
      http.addHeader("Content-Type", "application/x-www-form-urlencoded");

      // Mengirimkan data asli. Jika bernilai 999, kirim 0 atau penanda lain ke database Anda
      String httpRequestData = "jarak1=" + String(jarak1 == 999.0 ? 0 : jarak1) + 
                               "&jarak2=" + String(jarak2 == 999.0 ? 0 : jarak2) + 
                               "&jarak3=" + String(jarak3 == 999.0 ? 0 : jarak3);

      int httpResponseCode = http.POST(httpRequestData);
      if (httpResponseCode > 0) {
        Serial.print("Data Terkirim, Kode Respon: "); Serial.println(httpResponseCode);
      } else {
        Serial.print("Error kirim DB: "); Serial.println(httpResponseCode);
      }
      http.end();
    } else {
      Serial.println("WiFi terputus, mencoba menghubungkan ulang...");
      WiFi.begin(ssid, password);
    }
  }

  // -----------------------------------------------------------------
  // LOGIKA 2: PEMETAAN & PRIORITAS JARAK TERDEKAT (KONTROL BUZZER)
  // -----------------------------------------------------------------
  
  // Menggunakan fungsi min() untuk mengambil nilai terkecil (Prioritas Bahaya Tertinggi)
  // Buzzer 1 dipengaruhi oleh Sensor 1 dan Sensor 3
  float jarakEfektifBuzzer1 = min(jarak1, jarak3);
  // Buzzer 2 dipengaruhi oleh Sensor 2 dan Sensor 3
  float jarakEfektifBuzzer2 = min(jarak2, jarak3);

  // --- KONTROL BUZZER 1 ---
  if (jarakEfektifBuzzer1 <= 15.0) {
    // RULE 1: Dekat (0-15 cm) -> Sangat Bahaya / Berbunyi Terus
    digitalWrite(BUZZER_PIN1, HIGH);
  } 
  else if (jarakEfektifBuzzer1 > 15.0 && jarakEfektifBuzzer1 <= 30.0) {
    // RULE 2: Sedang (>15-30 cm) -> Peringatan / Berjeda (Contoh: setiap 200ms)
    int jedaBuzzer1 = 200; 
    if (waktuSekarang - waktuBuzzer1 >= jedaBuzzer1) {
      waktuBuzzer1 = waktuSekarang;
      statusBuzzer1 = !statusBuzzer1; // Bolak-balik status HIGH/LOW
      digitalWrite(BUZZER_PIN1, statusBuzzer1);
    }
  } 
  else {
    // RULE 3: Jauh (>30 cm) -> Aman / Mati
    digitalWrite(BUZZER_PIN1, LOW);
  }

  // --- KONTROL BUZZER 2 ---
  if (jarakEfektifBuzzer2 <= 15.0) {
    // RULE 1: Dekat (0-15 cm) -> Sangat Bahaya / Berbunyi Terus
    digitalWrite(BUZZER_PIN2, HIGH);
  } 
  else if (jarakEfektifBuzzer2 > 15.0 && jarakEfektifBuzzer2 <= 30.0) {
    // RULE 2: Sedang (>15-30 cm) -> Peringatan / Berjeda
    int jedaBuzzer2 = 200; 
    if (waktuSekarang - waktuBuzzer2 >= jedaBuzzer2) {
      waktuBuzzer2 = waktuSekarang;
      statusBuzzer2 = !statusBuzzer2; // Bolak-balik status HIGH/LOW
      digitalWrite(BUZZER_PIN2, statusBuzzer2);
    }
  } 
  else {
    // RULE 3: Jauh (>30 cm) -> Aman / Mati
    digitalWrite(BUZZER_PIN2, LOW);
  }
}
